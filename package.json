{
  "name": "@anusha-hegde-08/spec-pilot",
  "version": "0.1.0",
  "description": "A CLI tool that converts plain English feature specs into production-ready TypeScript code and tests using the OpenAI API",
  "type": "module",
  "bin": {
    "spec-pilot": "bin/run.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "bin"
  ],
  "keywords": [
    "cli",
    "ai",
    "openai",
    "typescript",
    "code-generation",
    "spec-driven-development",
    "developer-tools"
  ],
  "author": "Sindhoor",
  "license": "MIT",
  "dependencies": {
    "openai": "^4.0.0",
    "commander": "^12.0.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
